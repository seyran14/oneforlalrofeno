---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header';
---

<BaseLayout title="Seyran — Home">
  <div class="min-h-screen px-6 md:px-12 py-12 md:py-20">
    <div class="max-w-4xl mx-auto">
      
      {/* Header with Navigation */}
      <Header client:load />

      {/* Hero Section */}
      <div class="py-20 text-center">
        <h2 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-white via-zinc-300 to-zinc-500 bg-clip-text text-transparent">
          Welcome
        </h2>
        <p class="text-xl md:text-2xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
          A collection of posts, thoughts, and media.
        </p>
        
        <div class="mt-12 flex flex-wrap justify-center gap-4">
          <a 
            href="/posts" 
            class="px-8 py-3 bg-white text-black rounded-lg font-medium hover:bg-zinc-200 transition-colors"
          >
            View Posts
          </a>
          <a 
            href="/thoughts" 
            class="px-8 py-3 border border-zinc-700 text-white rounded-lg font-medium hover:border-zinc-500 transition-colors"
          >
            Read Thoughts
          </a>
          <a 
            href="/media" 
            class="px-8 py-3 border border-zinc-700 text-white rounded-lg font-medium hover:border-zinc-500 transition-colors"
          >
            Explore Media
          </a>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
