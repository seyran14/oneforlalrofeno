---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header';
import Post from '../components/Post';
---

<BaseLayout title="seyran">
  <div class="min-h-screen px-6 md:px-12 py-12 md:py-20">
    <div class="max-w-4xl mx-auto">
      
      {/* Header Component */}
      <Header client:load />

      {/* Posts Section */}
      <div class="space-y-0">
        
        {/* Post 1 */}
        <Post 
          client:load
          title="My first post on my own website"
          date="18 Feb 2026"
        >
          <p>
            My site. A long live project which maybe will take my whole life.
          </p>
          <p>
            This is only the beginning.
          </p>
        </Post>
          <pre class="bg-zinc-900 p-4 rounded-lg overflow-x-auto"><code>{`<Post 
  client:load
  title="Post name..."
  date="Date..."
>
  <p>Post text...</p>
</Post>`}</code></pre>
          <p>
            Coming soon...
          </p>
        </Post>

      </div>

    </div>
  </div>
</BaseLayout>
