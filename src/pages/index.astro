---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header';
import Post from '../components/Post';
import { getPostsFromNotion } from '../lib/notion';

// Получаем посты из Notion
const posts = await getPostsFromNotion();
---

<BaseLayout title="Seyran — Мой сайт">
  <div class="min-h-screen px-6 md:px-12 py-12 md:py-20">
    <div class="max-w-4xl mx-auto">
      
      {/* Header Component */}
      <Header client:load />

      {/* Posts Section */}
      <div class="space-y-0">
        
        {posts.length > 0 ? (
          posts.map((post) => (
            <Post 
              client:load
              title={post.title}
              date={post.date}
            >
              {/* Разбиваем контент на параграфы */}
              {post.content.split('\n\n').map((paragraph) => (
                paragraph.trim() && <p set:html={paragraph.replace(/\n/g, '<br />')} />
              ))}
            </Post>
          ))
        ) : (
          <div class="text-center py-20">
            <p class="text-zinc-500 text-lg">
              Постов пока нет. Добавь первый пост в Notion!
            </p>
          </div>
        )}

      </div>

    </div>
  </div>
</BaseLayout>
