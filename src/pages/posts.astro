---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header';
import Post from '../components/Post';
import { getPostsFromNotion } from '../lib/notion';

const posts = await getPostsFromNotion();
---

<BaseLayout title="Posts — Seyran">
  <div class="min-h-screen px-6 md:px-12 py-12 md:py-20">
    <div class="max-w-4xl mx-auto">
      
      {/* Header with Navigation */}
      <Header client:load />

      {/* Page Title */}
      <div class="mb-12">
        <h1 class="text-4xl font-bold text-white mb-2">Posts</h1>
        <p class="text-zinc-500">Long-form writing and articles</p>
      </div>

      {/* Posts Section */}
      <div class="space-y-0">
        
        {posts.length > 0 ? (
          posts.map((post) => (
            <Post 
              client:load
              title={post.title}
              date={post.date}
            >
              {post.content.split('\n\n').map((paragraph) => (
                paragraph.trim() && <p set:html={paragraph.replace(/\n/g, '<br />')} />
              ))}
            </Post>
          ))
        ) : (
          <div class="text-center py-20">
            <p class="text-zinc-500 text-lg">
              No posts yet. Add your first post in Notion!
            </p>
          </div>
        )}

      </div>

    </div>
  </div>
</BaseLayout>
